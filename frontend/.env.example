# Jarvis dashboard — frontend env (Phase 4 sub-phase 4.0).
# Copy to .env.local and fill in. .env.local is gitignored; this file is not.

# Auth.js v5 session secret — signs/encrypts the dashboard session cookie.
# MUST equal the backend's AUTH_SECRET: the wake-word WebSocket ticket is signed
# here (BFF /api/voice/wake-ticket) and verified by the backend (_verify_jwt)
# with this shared key. The BFF HTTP path is still independent, but rotating only
# one side breaks the wake-word — rotate BOTH together. Generate: openssl rand -hex 32
AUTH_SECRET=

# The single-master passkey checked by the Credentials provider (src/auth.ts).
# This is what you type on the login screen.
MASTER_PASSKEY=

# --- server-side only (never NEXT_PUBLIC_*; the browser never sees these) ---
# The FastAPI backend base URL. Host dev: http://localhost:8000.
# Containerised later: http://backend:8000 (compose service DNS).
JARVIS_BACKEND_URL=http://localhost:8000
# The backend's API_SECRET_KEY. BFF route handlers (src/app/api/**) attach this
# as X-API-Key and proxy to the backend after verifying the dashboard session.
JARVIS_API_KEY=

# --- voice-in (Phase 4.2 wake-word) ---
# Backend WebSocket base for the "hey jarvis" wake-word stream (browser mic →
# backend openWakeWord). No account/key needed (server-side detection). Host dev:
# ws://localhost:8000 ; containerised/prod: wss://<host>. The command STT after
# wake uses the browser Web Speech API (Chrome).
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:8000
