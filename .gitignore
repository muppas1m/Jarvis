# Secrets — never commit these
.env
backend/secrets/
*.pem
google_credentials.json

# Pre-implementation reference / scratch — explicitly excluded by the user
old_files/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Node / Next.js
node_modules/
.next/
.turbo/
out/
dist/
build/

# Docker bind mounts (the named volumes are managed by Docker, not committed,
# but listed here in case anyone accidentally creates host-side mounts of the same name)
postgres_data/
redis_data/
langfuse_db_data/
langfuse_clickhouse_data/

# OS / IDE
.DS_Store
.vscode/
.idea/
*.swp

# Editor/agent caches
.aider*
.claude_local/

# Local-only commit depth log — reference for the human, never version-controlled
commits.md

# Eval run artifacts — keep only the committed baseline.json
backend/evals/results/*.json
!backend/evals/results/baseline.json

# Local DB backups — real master data, never commit (durable across reboots)
backend/backups/
